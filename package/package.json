{
  "name": "asdf-fox",
  "version": "0.1.1",
  "description": "Inspectable password-strength analysis built on a bundled zxcvbn-ts baseline, a contemporary vocabulary overlay, targeted structural detectors, and opt-in Pwned Passwords checks.",
  "keywords": [
    "password",
    "zxcvbn",
    "password-strength",
    "pwned-passwords",
    "hibp",
    "security"
  ],
  "license": "MIT",
  "type": "commonjs",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "data/wordfreq-en-2021.metadata.json",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "NOTICE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "@zxcvbn-ts/language-en": "^4.1.1",
    "esbuild": "^0.27.0"
  }
}
